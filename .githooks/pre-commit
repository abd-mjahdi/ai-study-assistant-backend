#!/usr/bin/env sh

# Blocks commits that contain likely secrets in staged changes.

PATTERN='AIza[0-9A-Za-z_-]{20,}|sk-[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|(api|db|jwt|gemini)[._-]?(key|secret|password)\s*[:=]\s*["'"'"']?[A-Za-z0-9_+\/=.-]{8,}'
MATCHES=$(git diff --cached -U0 | rg -n "$PATTERN" || true)

if [ -n "$MATCHES" ]; then
  echo "ERROR: possible secret detected in staged changes."
  echo "$MATCHES"
  echo "Commit blocked. Move secrets to environment variables."
  exit 1
fi

exit 0
