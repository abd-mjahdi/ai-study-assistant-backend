# =============================================================================
# Copy this file to .env (same folder):  copy .env.example .env
# Then fill JWT_SECRET + GEMINI_API_KEY at minimum. Never commit .env.
# Run full stack:  docker compose up --build
# API: http://localhost:8080   |   DB host port: localhost:5432 (from container)
# =============================================================================

# --- Docker Compose → Postgres (`db` service) + backend JDBC -----------------
POSTGRES_DB=aiassistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DB_PORT=5432
BACKEND_PORT=8080

# --- Secrets (backend container env → Spring placeholders in application.properties)
# JWT: generate a long random secret (e.g. 32+ chars). Base64 is fine if long enough.
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# CORS — dev default permissive; tighten for production (comma-separated patterns)
CORS_ALLOWED_ORIGIN_PATTERNS=*

# --- Optional: run Spring on your machine (IDE) against Docker Postgres ----------
# Uncomment only when NOT using `docker compose` for the backend. DB must match
# POSTGRES_* above and Postgres must expose DB_PORT on localhost (compose does).
# DB_URL=jdbc:postgresql://localhost:5432/aiassistant
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
